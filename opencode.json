{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "laravel-boost": {
            "type": "local",
            "enabled": true,
            "command": [
                "./.infrastructure/scripts/mcp-wait.sh",
                "./vendor/bin/spin",
                "run",
                "-T",
                "php",
                "php",
                "artisan",
                "boost:mcp"
            ]
        }
    }
}